{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "/dist/favicon.svg"
    },
    {
      "src": "/hero.png",
      "dest": "/dist/hero.png"
    },
    {
      "src": "/icons.svg",
      "dest": "/dist/icons.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ]
}